ANTHROPIC_API_KEY=sk-ant-...

# OpenEMR FHIR endpoint (no trailing slash). Local dev uses https on :9300 with self-signed cert.
OPENEMR_FHIR_BASE=https://host.docker.internal:9300/apis/default/fhir
OPENEMR_OAUTH_BASE=https://host.docker.internal:9300/oauth2/default
# Set false ONLY for local self-signed dev cert. Real production keeps verification on.
OPENEMR_VERIFY_TLS=false

# OAuth2 client credentials (registered with OpenEMR via /oauth2/default/registration)
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_SCOPES=system/Patient.read system/Observation.read system/MedicationRequest.read system/Condition.read system/Encounter.read system/AllergyIntolerance.read system/DocumentReference.read system/Binary.read

# Langfuse (cloud free tier or self-hosted)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# For demo: hard-coded acting physician identity until SMART launch handshake is wired
DEMO_PHYSICIAN_USER_ID=admin
DEMO_PHYSICIAN_USERNAME=admin

# Set to "1" to use respx-mocked FHIR (offline dev / fallback if Railway FHIR is broken)
USE_MOCK_FHIR=0
