{
  "name": "openemr-interface",
  "version": "0.2.0",
  "description": "UI toolkit, theme and component library for OpenEMR",
  "main": "index.js",
  "scripts": {
    "postinstall": "napa && node scripts/install-assets.js",
    "build": "npm run build:webpack:prod && npm run build:sync",
    "build:webpack": "webpack --config webpack.themes.js",
    "build:webpack:prod": "npm run build:webpack -- --mode production",
    "build:webpack:dev": "npm run build:webpack -- --mode development",
    "build:sync": "node scripts/sync-css.js",
    "dev": "npm run build:webpack:dev && npm run build:sync && npm run watch",
    "watch": "webpack --config webpack.themes.js --mode development --watch",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint:js": "eslint '**/*.js' --quiet",
    "lint:js-fix": "npm run lint:js -- --fix",
    "test:js": "jest",
    "test:js-coverage": "jest --coverage",
    "stylelint": "npx stylelint '**/*.{css,scss}'",
    "stylelint-fix": "npm run stylelint -- --fix"
  },
  "keywords": [
    "openemr"
  ],
  "author": "d3sandoval",
  "license": "GNU GPL",
  "engines": {
    "node": ">=24.0.0"
  },
  "browserslist": [
    "> 1%",
    "ie >= 8",
    "edge >= 15",
    "ie_mob >= 10",
    "ff >= 45",
    "chrome >= 45",
    "safari >= 7",
    "opera >= 23",
    "ios >= 7",
    "android >= 4",
    "bb >= 10"
  ],
  "devDependencies": {
    "@types/jest": "29.5.14",
    "autoprefixer": "10.5.2",
    "css-loader": "6.11.0",
    "css-minimizer-webpack-plugin": "8.0.0",
    "eslint": "9.39.5",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "28.14.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "30.4.1",
    "mini-css-extract-plugin": "2.10.2",
    "napa": "3.0.0",
    "postcss": "8.5.18",
    "postcss-loader": "7.3.4",
    "sass": "1.101.0",
    "sass-loader": "13.3.3",
    "stylelint": "16.26.1",
    "stylelint-config-sass-guidelines": "12.1.0",
    "stylelint-config-standard": "37.0.0",
    "stylelint-order": "6.0.4",
    "stylelint-scss": "6.14.0",
    "webpack": "5.108.4",
    "webpack-cli": "5.1.4"
  },
  "dependencies": {
    "@eastdesire/jscolor": "2.5.2",
    "@fortawesome/fontawesome-free": "6.7.2",
    "backbone": "1.6.1",
    "bootstrap": "4.6.2",
    "bootswatch": "4.6.2",
    "chart.js": "4.5.1",
    "chartjs-adapter-date-fns": "3.0.0",
    "ckeditor5": "47.6.2",
    "datatables.net": "1.13.11",
    "datatables.net-bs4": "1.13.11",
    "datatables.net-colreorder": "1.7.2",
    "datatables.net-colreorder-dt": "1.7.2",
    "datatables.net-dt": "1.13.11",
    "datatables.net-jqui": "1.13.11",
    "datatables.net-scroller": "2.4.3",
    "datatables.net-scroller-jqui": "2.4.3",
    "dompurify": "3.4.12",
    "dropzone": "5.9.3",
    "dwv": "0.27.1",
    "flot": "4.2.6",
    "hotkeys-js": "3.13.15",
    "i18next": "24.2.3",
    "i18next-browser-languagedetector": "8.2.1",
    "i18next-xhr-backend": "3.2.2",
    "interactjs": "1.10.27",
    "jquery": "3.7.1",
    "jquery-datetimepicker": "2.5.21",
    "jquery-validation": "1.22.1",
    "jspdf": "4.2.1",
    "jszip": "3.10.1",
    "knockout": "3.5.3",
    "konva": "9.3.22",
    "magic-wand-js": "1.0.0",
    "moment": "2.30.1",
    "numeral": "2.0.6",
    "purecss": "3.0.0",
    "select2": "4.1.0",
    "sortablejs": "1.15.7",
    "summernote": "0.9.1",
    "underscore": "1.13.8",
    "utif2": "4.1.0",
    "validate.js": "0.13.1"
  },
  "napa": {
    "bootstrap-rtl": "https://github.com/PerseusTheGreat/bootstrap-4-rtl/archive/643a8f9e221ed86729b51913d1a7d5614e615682.zip",
    "jquery-creditcardvalidator": "https://github.com/PawelDecowski/jquery-creditcardvalidator/archive/v1.1.0.tar.gz",
    "jquery-panelslider": "https://github.com/eduardomb/jquery-panelslider/archive/1.0.0.tar.gz",
    "jquery-ui": "https://jqueryui.com/resources/download/jquery-ui-1.12.1.zip",
    "jquery-ui-themes": "https://jqueryui.com/resources/download/jquery-ui-themes-1.12.1.zip",
    "literallycanvas": "https://github.com/literallycanvas/literallycanvas/archive/v0.4.14.tar.gz",
    "react": "https://github.com/facebook/react/releases/download/v15.1.0/react-15.1.0.zip"
  },
  "napa-config": {
    "cache": false
  }
}
