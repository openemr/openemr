# Clinical Co-Pilot sidecar config — copy to .env and fill in.
# Never commit a populated .env; the .gitignore excludes it.

# ─── LLM ────────────────────────────────────────────────────────────────────
# Provider: "openai" (Enterprise BAA + ZDR), "azure" (Azure OpenAI BAA), or
# "mock" for offline / CI runs that use the deterministic mock provider.
COPILOT_LLM_PROVIDER=mock
COPILOT_OPENAI_MODEL=gpt-5
OPENAI_API_KEY=
OPENAI_BASE_URL=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=

# ─── OpenEMR FHIR ──────────────────────────────────────────────────────────
COPILOT_OPENEMR_FHIR_BASE=https://localhost:9300/apis/default/fhir
COPILOT_OPENEMR_OAUTH_BASE=https://localhost:9300/oauth2/default
COPILOT_OPENEMR_CLIENT_ID=clinical-copilot
COPILOT_OPENEMR_CLIENT_SECRET=
# Set to "true" when developing against the self-signed dev certificate.
COPILOT_FHIR_VERIFY_SSL=false

# ─── Snapshot cache + audit log ────────────────────────────────────────────
COPILOT_DATABASE_URL=postgresql+psycopg://copilot:copilot@localhost:5433/copilot
COPILOT_SNAPSHOT_TTL_SECONDS=86400        # 24 hours per ARCHITECTURE.md §2.2
COPILOT_AUDIT_RETENTION_DAYS=2555          # 7 years per §6.3

# ─── Observability ─────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=clinical-copilot
COPILOT_LANGFUSE_HOST=
COPILOT_LANGFUSE_PUBLIC_KEY=
COPILOT_LANGFUSE_SECRET_KEY=

# ─── BFF ───────────────────────────────────────────────────────────────────
COPILOT_BFF_HOST=0.0.0.0
COPILOT_BFF_PORT=8800
COPILOT_SIDECAR_HOST=0.0.0.0
COPILOT_SIDECAR_PORT=8801
COPILOT_TASK_TOKEN_LIFETIME_SECONDS=300    # 5 minutes per §3.2
COPILOT_BFF_JWT_SIGNING_KEY=change-me-to-a-32-byte-hex-string

# ─── PHI scrubber ──────────────────────────────────────────────────────────
COPILOT_PHI_SCRUB_ENABLED=true
