        <input type="hidden" name="id" value="{{prescription.id|attr}}" />
        <input type="hidden" name="process" value="{{PROCESS|attr}}" />
        <input type="hidden" id="rxnorm_drugcode" name="rxnorm_drugcode" value="{{prescription.rxnorm_drugcode|attr}}" />
        {% if dispenseEnabled %}
        <input type="hidden" name="dispense_after_save" value="" />
        {% endif %}
        <input type="hidden" name="print_after_save" value="" />

        <script>
            {# TODO: @adunsulag Why in the world do we have just raw injection of javascript here... #}
            {% if ENDING_JAVASCRIPT is not empty %}{{ ENDING_JAVASCRIPT }}{% endif %}
        </script>
    </form>
</div>

<!-- for the fancy jQuery stuff -->
<script>
    {% if dispenseEnabled %}

    // Validate the dispense form, then submit with dispense_after_save=1.
    // The controller handles both new and existing prescriptions in the
    // same path and opens the bottle-label popup after the sale completes.
    function dispense() {
        var f = document.forms[0];
        if (f.disp_quantity.value == "" || isNaN(f.disp_quantity.value) || parseInt(f.disp_quantity.value) <= 0) {
            alert({{'Please enter a valid dispense quantity'|xlj}});
            f.disp_quantity.focus();
            return false;
        }
        if (f.dispense_encounter_id.value == "" || isNaN(f.dispense_encounter_id.value) || parseInt(f.dispense_encounter_id.value) <= 0) {
            alert({{'Dispensing a drug requires a linked encounter'|xlj}});
            f.dispense_encounter_id.focus();
            return false;
        }
        let drugId = parseInt(f.dispense_drug_id.value || 0);
        if (drugId <= 0) {
            alert({{'Please select an in-house drug to dispense'|xlj}});
            f.drug_id.focus();
            return false;
        }
        // Loose mode + off-site lot: force an explicit acknowledgement.
        // In strict mode off-site options are disabled and cannot reach
        // this point; in loose mode the user is overriding a clinic
        // convention and we want a deliberate click.
        if (!lotPickerRestrictToDefault) {
            var $lotOpt = $('#dispense_inventory_id option:selected');
            if ($lotOpt.attr('data-off-site') === '1') {
                if (!confirm({{'The selected lot is not in your default warehouse. Confirm only if you are physically dispensing from this exact lot.'|xlj}})) {
                    f.dispense_inventory_id.focus();
                    return false;
                }
            }
        }

        f.dispense_after_save.value = "1";
        top.restoreSession();
        if (CheckForErrors(f)) {
            f.submit();
        }
        return false;
    }
    function toggleDispense() {
        $('.dispense_option,.prescription-controls .btn-primary,.prescription-controls .btn-save-print,.amc-card').toggle();
        $('.btn.btn-toggle-dispense').toggle();
    }

    // Tracks the lot-picker mode delivered by the AJAX endpoint:
    //  - hasDefaultWarehouse: the user has a default warehouse configured.
    //    When false, "on-site" has no anchor; show the danger banner,
    //    skip per-selection off-site flags, and skip the off-site confirm.
    //  - restrictToDefault: the clinic's restrict_sales_to_default_warehouse
    //    flag. When true, off-site lots are rendered disabled (sellDrug()
    //    would block them server-side anyway); when false, they are
    //    selectable with a warning + submit-time confirm.
    var lotPickerHasDefaultWarehouse = true;
    var lotPickerRestrictToDefault = true;

    // Toggle the off-site warning panel based on whether the currently
    // selected lot is flagged as off-site (data-off-site="1"). Suppressed
    // when no default warehouse is set, or when strict mode is on (in
    // strict mode, off-site lots are disabled and cannot be selected).
    function updateOffSiteWarning() {
        if (!lotPickerHasDefaultWarehouse || lotPickerRestrictToDefault) {
            $('#off_site_warning').hide();
            return;
        }
        var $sel = $('#dispense_inventory_id');
        var $opt = $sel.find('option:selected');
        var isOffSite = $opt.attr('data-off-site') === '1';
        $('#off_site_warning').toggle(isOffSite);
    }

    // Repopulate the lot dropdown when the selected in-house drug changes.
    // The first lot returned is the one sellDrug() would auto-pick (default
    // warehouse, nearest expiration), so we preselect it.
    function loadLotsForDrug(drugId) {
        var $sel = $('#dispense_inventory_id');
        $('#off_site_warning').hide();
        $('#no_default_warehouse_warning').hide();
        $('#strict_mode_notice').hide();
        $sel.prop('disabled', true).empty();
        if (!drugId || drugId <= 0) {
            $sel.append($('<option>').val('').text({{'Select an in-house drug to load lots'|xlj}}));
            return;
        }
        $sel.append($('<option>').val('').text({{'Loading...'|xlj}}));
        top.restoreSession();
        $.getJSON({{ webroot|js_escape }} + '/library/ajax/drug_lots.php', {
            csrf_token_form: {{ CSRF_TOKEN_FORM|js_escape }},
            drug_id: drugId
        }).done(function(data) {
            $sel.empty();
            var lots = (data && data.lots) ? data.lots : [];
            lotPickerHasDefaultWarehouse = !!(data && data.has_default_warehouse);
            lotPickerRestrictToDefault = !!(data && data.restrict_to_default);
            // Show the configuration banner when no default warehouse is
            // set. Show the strict-variant of the message when the clinic
            // also enforces the restriction — in that case the dispense
            // button must be disabled too, because sellDrug() will refuse.
            var noDefault = !lotPickerHasDefaultWarehouse;
            $('#no_default_warehouse_warning').toggle(noDefault);
            $('#no_default_warehouse_warning .no-default-loose').toggle(noDefault && !lotPickerRestrictToDefault);
            $('#no_default_warehouse_warning .no-default-strict').toggle(noDefault && lotPickerRestrictToDefault);
            var blockSubmit = noDefault && lotPickerRestrictToDefault;
            $('.btn-presc-dispense').prop('disabled', blockSubmit);
            // In strict mode, surface why off-site lots in the dropdown
            // are greyed out — only when there are off-site lots to explain.
            var hasOffSite = false;
            $.each(lots, function(idx, l) { if (l.is_off_site) { hasOffSite = true; return false; } });
            $('#strict_mode_notice').toggle(lotPickerRestrictToDefault && lotPickerHasDefaultWarehouse && hasOffSite);
            if (lots.length === 0) {
                $sel.append($('<option>').val('').text({{'No available lots for this drug'|xlj}}));
                return;
            }
            var firstSelectableId = null;
            $.each(lots, function(idx, lot) {
                var label = lot.lot_number || {{'(no lot number)'|xlj}};
                if (lot.warehouse_title) {
                    label += ' — ' + lot.warehouse_title;
                }
                if (lot.expiration) {
                    label += ' — ' + {{'exp'|xlj}} + ' ' + lot.expiration;
                }
                label += ' — ' + lot.on_hand + ' ' + {{'on hand'|xlj}};
                // Only show the [OFF-SITE] prefix when we have a real
                // anchor (a default warehouse). Without one, every row
                // would be flagged and the prefix would be noise — the
                // danger banner already explains the situation.
                var flagOffSite = lot.is_off_site && lotPickerHasDefaultWarehouse;
                if (flagOffSite) {
                    label = {{'[OFF-SITE]'|xlj}} + ' ' + label;
                }
                var $opt = $('<option>').val(lot.inventory_id).text(label);
                $opt.attr('data-off-site', flagOffSite ? '1' : '0');
                // In strict mode, off-site rows are visible but locked —
                // sellDrug() would refuse them anyway.
                if (flagOffSite && lotPickerRestrictToDefault) {
                    $opt.prop('disabled', true);
                } else if (firstSelectableId === null) {
                    firstSelectableId = lot.inventory_id;
                }
                $sel.append($opt);
            });
            $sel.prop('disabled', false);
            // Default to the first selectable lot. Falls back to the first
            // row if everything is disabled (so the dropdown isn't blank).
            $sel.val(firstSelectableId !== null ? firstSelectableId : lots[0].inventory_id);
            updateOffSiteWarning();
        }).fail(function() {
            $sel.empty().append($('<option>').val('').text({{'Failed to load lots'|xlj}}));
        });
    }

    $(document).ready(function(){
        $(".btn.btn-toggle-dispense").click(function(){
            toggleDispense();
        });
        $('.btn-presc-dispense').click(function(evt) {
            evt.preventDefault();
            dispense();
            return false;
        });
        // Initial load when the form opens with a drug already selected
        // (existing prescription with refills, or returning from a server-side error).
        var initialDrugId = parseInt(document.forms[0].dispense_drug_id.value || 0);
        if (initialDrugId > 0) {
            loadLotsForDrug(initialDrugId);
        }
        // Refresh on drug change. drugselected() lives in <head> and runs
        // before this handler, so by the time we read dispense_drug_id it
        // already has the new value.
        $(document).on('change', '[name="drug_id"]', function() {
            var f = document.forms[0];
            var newDrugId = parseInt(f.dispense_drug_id.value || 0);
            loadLotsForDrug(newDrugId);
        });
        // Toggle off-site warning whenever the lot selection changes.
        $(document).on('change', '#dispense_inventory_id', updateOffSiteWarning);
    });
    {% endif %}

