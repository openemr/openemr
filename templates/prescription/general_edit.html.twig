// This is for callback by the select codes popup.
// Appends to or erases the current list of diagnoses.
function OnCodeSelected(codetype, code, selector, codedesc) {
    var codeKey = codetype + ':' + code
    let option = document.createElement('option');
    option.value = codeKey; // escaped via DOM
    option.textContent = codeKey + ' (' + codedesc + ')'; // escaped via DOM
    let select = document.getElementById('form_selected_codes');
    if (!select) {
        console.error("Could not find selected codes element");
    }
    select.appendChild(option);
}
