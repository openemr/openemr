{# Renders one mini-calendar month grid. Shared by print and on-screen
   views (each passes the right CSS class set via `hideOutOfMonth`).

   Inputs:
   - mini : dict from CalendarViewModel::buildMiniCalendar() with keys
       monthLabel, year, month, weeks[].day{dateYmd,day,inMonth,isWeekend,isCurrent}
   - dowList : list of 7 int day-of-week indices
   - dayNames : list of localized short day names indexed 0..6
   - hideOutOfMonth : when true (print views), out-of-month cells render as
       <td></td>. When false (screen views), they render with the
       tdOtherMonthDay-small CSS class. #}

<table>
    <tr>
        <td colspan="7" class="tdMonthName-small">{{ mini.monthLabel|xlt }} {{ mini.year|text }}</td>
    </tr>
    <tr>
        {% for dow in dowList %}
            <td class="tdDOW-small">{{ dayNames[dow]|text }}</td>
        {% endfor %}
    </tr>
    {% for week in mini.weeks %}
        <tr>
            {% for day in week %}
                {% if hideOutOfMonth and not day.inMonth %}
                    <td></td>
                {% else %}
                    {% set tdClass = day.inMonth ? 'tdMonthDay-small' : 'tdOtherMonthDay-small' %}
                    {% if day.isWeekend %}
                        {% set tdClass = 'tdWeekend-small' %}
                    {% endif %}
                    {% if day.isCurrent %}
                        {% set tdClass = tdClass ~ ' currentDate' %}
                    {% endif %}
                    {% set tdClass = tdClass ~ ' tdDatePicker' %}
                    <td class="{{ tdClass|attr }}" id="{{ day.dateYmd|attr }}" title="Go to week of {{ day.dateYmd|attr }}"> {{ day.day|text }}</td>
                {% endif %}
            {% endfor %}
        </tr>
    {% endfor %}
</table>
