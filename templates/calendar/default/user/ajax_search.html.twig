{# Calendar search form + result table. Smarty→Twig conversion of
   user/ajax_search.html. The legacy template had 14 [-php-] blocks
   ranging from trivial $GLOBALS echoes to a 62-line block that did per-row
   DB lookups for provider info. That work moves to the consumer (Phase 9):
   the template now expects search_results as a pre-decorated flat list
   of event dicts and datepicker_xl as a pre-built JS-config string. #}
{% include 'calendar/default/views/header.html.twig' %}

{# include our stylesheet for this view #}
<link rel="stylesheet" href="{{ assets_dir }}/jquery-datetimepicker/build/jquery.datetimepicker.min.css">

<script src="{{ assets_dir }}/jquery-datetimepicker/build/jquery.datetimepicker.full.min.js"></script>

<!-- main navigation -->

<div class="container mt-3">
    <div class="row">
        <div class="col-12 mb-3">
            <a href="{{ webroot }}/interface/main/main_info.php" class="btn btn-secondary btn-lg" onclick="top.restoreSession()">
                <i class="fa fa-arrow-left mr-1"></i> {{ 'Return to Calendar'|xlt }}
            </a>
        </div>
        <div class="col-12">
            <h2>{{ 'Searching for appointments'|xlt }}</h2>
        </div>
        <div class="col-12">
            <form name="theform" id="theform" action="{{ FORM_ACTION|safe_href }}" method="post"> <!-- onsubmit="return top.restoreSession()"> -->
                <!-- Keywords -->
                <div class="form-group">
                    <label for="pc_keywords">{{ 'Keywords'|xlt }}:</label>
                    <div class="form-row">
                        <div class="col-md-8">
                            <input type="text" class="form-control" name="pc_keywords" id="pc_keywords"
                                placeholder="{{ 'Search patients, providers, appointments, or comments'|xla }}"
                                value="{{ keywords_value|default('')|attr }}" />
                        </div>
                        <div class="col-md-4">
                            <select class="form-control" name="pc_keywords_andor" id="pc_keywords_andor" disabled>
                                <option value="AND" {% if keywords_andor|default('AND') == 'AND' %}selected{% endif %}>{{ 'AND'|xlt }}</option>
                                <option value="OR" {% if keywords_andor|default('') == 'OR' %}selected{% endif %}>{{ 'OR'|xlt }}</option>
                            </select>
                        </div>
                    </div>
                    <small class="form-text text-muted">{{ 'For multiple words, separate with spaces and select AND/OR'|xlt }}</small>
                </div>
                <!-- In Category -->
                <div class="form-group">
                    <label for="pc_category">{{ 'In'|xlt }}:</label>
                    <select class="form-control" name="pc_category" id="pc_category">
                        <option value="">{{ 'Any Category'|xlt }}</option>
                        {{ CATEGORY_OPTIONS|raw }}
                    </select>
                </div>
                <!-- Topic -->
                {% if USE_TOPICS %}
                <div class="form-group">
                    <select name="pc_topic">
                        <option value="">{{ _PC_SEARCH_ANY_TOPIC }}</option>
                        {{ TOPIC_OPTIONS|raw }}
                    </select>
                </div>
                {% endif %}
                <br />
                <!-- Between -->
                <div class="form-row">
                    <div class="col">
                        <label for="start">{{ 'Between'|xlt }}:</label>
                        <input type="text" class="form-control datepicker" name="start" id="start" value="{{ DATE_START|attr }}" size="10"/>
                    </div>
                    <div class="col">
                        <label for="end">&nbsp;</label>
                        <input type="text" class="form-control datepicker" name="end" id="end" value="{{ DATE_END|attr }}" size="10"/>
                    </div>
                </div>
                <br />
                <!-- For At -->
                <div class="form-row">
                    <div class="col">
                        <label for="provider_id">{{ 'For'|xlt }}</label>
                        <select class="form-control" name="provider_id" id="provider_id">
                            {{ PROVIDER_OPTIONS|raw }}
                        </select>
                    </div>
                    <div class="col">
                        <label for="pc_facility">{{ 'At'|xlt }}</label>
                        <select class="form-control" name="pc_facility" id="pc_facility">
                            {{ FACILITY_OPTIONS|raw }}
                        </select>
                    </div>
                </div>
                <!-- Submit -->
                <div class="btn-group mt-2">
                    <button class="btn btn-primary btn-search" type="submit" name="submit" id="submit" value="{{ 'Submit'|xla }}">{{ 'Search'|xlt }}</button>
                </div>
                <div class="d-none" id="calsearch_status">
                    <img src="{{ webroot }}/interface/pic/ajax-loader.gif"> {{ 'Searching...'|xlt }}
                </div>
            </form>
            <!-- end of search parameters -->

            {% if SEARCH_PERFORMED is defined %}
            <div class="mt-3">
                <!-- Table Header -->
                <div class="table-responsive" class="head">
                    <table class="table">
                        <tr class="table-active">
                            <th>{{ 'Date'|xlt }}-{{ 'Time'|xlt }}</th>
                            <th>{{ 'Provider'|xlt }}</th>
                            <th>{{ 'Category'|xlt }}</th>
                            <th>{{ 'Patient'|xlt }}</th>
                        </tr>
                    </table>
                </div>
                <!-- Table Result -->
                <div class="table-responsive">
                    <table class="table">
                        {# search_results: flat list of event dicts pre-decorated by the consumer with
                           datetime_display (formatted "Y-m-d h:i a"), provider_name, provider_info_title
                           (multi-line tooltip with contact info), catname, patient_name, event_id_token
                           ("eid~yyyymmdd"). Replaces the legacy [-php-] block that did per-row sqlStatement
                           lookups during template render. #}
                        {% for event in search_results|default([]) %}
                            <tr class="calsearch_event" id="{{ event.event_id_token|attr }}" title="{{ 'Click to edit this event'|xla }}">
                                <td>{{ event.datetime_display|text }}</td>
                                <td>{{ event.provider_name|text }} <img class="provinfo" src="{{ globals.images_static_relative }}/info.png" title="{{ event.provider_info_title|attr }}" /></td>
                                <td>{{ event.catname|text }} </td>
                                <td>{{ event.patient_name|text }}</td>
                            </tr>
                        {% else %}
                            <tr><td colspan="4" class="text-center">{{ 'No Results'|xlt }}</td></tr>
                        {% endfor %}
                    </table>
                </div>  <!-- end results-data DIV -->
            </div>  <!-- end outer results DIV -->
            {% endif %}  {# end of SEARCH_PERFORMED #}
        </div>
    </div>
</div>

<script>

document.head.insertAdjacentHTML('beforeend', `
<style>
    .calsearch_event {
        cursor: pointer;
        transition: background-color 0.2s;
    }
    .calsearch_event:hover {
        background-color: #f0f0f5;
    }
</style>
`);

// jQuery stuff to make the page a little easier to use

$(function () {
    $("#pc_keywords").focus();
    $("#theform").submit(function() { SubmitForm(this); });
    $(".calsearch_event").click(function() { EditEvent(this); });

    $('.datepicker').datetimepicker({
        {# datepicker_xl is pre-rendered by the consumer by output-buffering
           library/js/xl/jquery-datetimepicker-2-5-4.js.php with these settings:
           $datetimepicker_timepicker = false;
           $datetimepicker_showseconds = false;
           $datetimepicker_formatInput = false; #}
        {{ datepicker_xl|raw }}
        ,format: 'm/d/Y'
    });

    // function to check keywords and toggle AND/OR selector
    function toggleAndOrSelector() {
        const keywords = $("#pc_keywords").val().trim();
        const hasMultipleWords = keywords.includes(' ');

        if (hasMultipleWords) {
            $("#pc_keywords_andor").prop('disabled', false);
        } else {
            $("#pc_keywords_andor").prop('disabled', true);
        }
    }

    // runs when the page loads
    toggleAndOrSelector();

    // runs when the user input gets changed
    $("#pc_keywords").on('input', toggleAndOrSelector);

    // pressing the enter key will search
    $('#theform input, #theform select').keypress(function(e) {
        if (e.which === 13) {
            e.preventDefault();
            $('#submit').click();
        }
    });
});

// open a pop up to edit the event
// parts[] ==>  0=eventID
const EditEvent = function (eObj) {
    objID = eObj.id;
    const parts = objID.split("~");
    dlgopen('add_edit_event.php?date=' + encodeURIComponent(parts[1]) + '&eid=' + encodeURIComponent(parts[0]), '_blank', 780, 675);
}

// show the 'searching...' status and submit the form
const SubmitForm = function(eObj) {
    $("submit").css("disabled", "true");
    $("#calsearch_status").removeClass('d-none')
    return top.restoreSession();
}

function goPid(pid) {
    top.restoreSession();
    top.RTop.location = '../../patient_file/summary/demographics.php' + '?set_pid=' + encodeURIComponent(pid);
 }
</script>
