[codespell]
# OpenEMR Codespell Configuration
# Run locally: codespell
# Same command runs in CI via .github/workflows/spellcheck.yml

# Skip patterns:
# - Gitignored directories (node_modules, vendor, etc.)
# - Binary and minified files
# - Auto-generated docs (Documentation/EHI_Export - SchemaSpy output)
# - Translation source files (generated by translation tool)
# - Vendored third-party code (bundled/minified JS with many false positives)
# - CHANGELOG.md + ChangelogGenerator fixture expected.md files: both
#   contain PR titles captured verbatim from live gh api state via
#   ChangelogMutator. Some historic PR titles include typos (e.g.,
#   "Dislay" in a PR that FIXED that typo elsewhere in the codebase);
#   ChangelogMutator wholesale-replaces sections on every release-prep
#   run, so hand-fixes would be wiped. Historical PR titles are
#   frozen upstream data -- codespell would fight that lock forever.
#   Fixture expected.md files carry the same content byte-for-byte
#   (regenerated via UPDATE_FIXTURE=1) and inherit the same problem.
skip = .git,node_modules,vendor,ccdaservice/node_modules,*.min.js,*.min.css,*.map,*.lock,*.woff,*.woff2,*.ttf,*.eot,*.ico,*.png,*.jpg,*.jpeg,*.gif,*.pdf,*.svg,*.eps,*.sql,*.dot,*.tsv,*.json,*.pem,CHANGELOG.md,**/public/assets/*,**/Documentation/EHI_Export/*,**/language_translations/*,**/gacl/*,**/interface/forms/questionnaire_assessments/lforms/*,**/interface/forms/eye_mag/js/shortcut.js-2-01-B/*,**/interface/modules/custom_modules/oe-module-comlink-telehealth/public/assets/js/dist/*,**/interface/modules/zend_modules/public/js/lib/*,**/interface/modules/zend_modules/public/xsd/*,**/interface/modules/zend_modules/public/xsl/*,**/interface/super/rules/www/js/cdr-multiselect/*,**/library/classes/fpdf/*,**/library/fonts/*,**/library/js/CategoryTreeMenu.js,**/library/js/DocumentTreeMenu.js,**/library/js/SearchHighlight.js,**/library/smarty_legacy/*,**/public/assets/modified/*,**/swagger/*,**/tests/Tests/Isolated/Release/fixtures/*/expected.md

ignore-words = .codespell-ignore-words.txt
exclude-file = .codespell-exclude-lines.txt
