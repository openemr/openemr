# OpenEMR OIDC server base URL — e.g. https://openemr-production-0c8c.up.railway.app
OPENEMR_OAUTH_BASE=

# OpenEMR FHIR R4 base URL on the same instance — e.g. https://openemr-production-0c8c.up.railway.app/apis/default/fhir
OPENEMR_FHIR_BASE=

# Confidential OAuth2 client registered for the dashboard.
# (Admin → System → API Clients in OpenEMR; redirect_uri = ${DASHBOARD_PUBLIC_URL}/api/auth/callback)
OPENEMR_DASHBOARD_CLIENT_ID=
OPENEMR_DASHBOARD_CLIENT_SECRET=

# Public-facing origin of this Next.js service. Used to build OAuth
# redirect_uri deterministically — never trusted from request headers.
# e.g. https://dashboard-production.up.railway.app
DASHBOARD_PUBLIC_URL=

# Co-Pilot Railway service base URL for the iframe embed
COPILOT_URL=

# Comma-separated OpenEMR usernames that bypass the panel-scope gate (admin allowlist)
COPILOT_ADMIN_USERS=

# 32+ char random string; encrypts the dashboard's httpOnly session cookie at rest
SESSION_COOKIE_SECRET=

# Set to "false" only for local dev with self-signed certs; "true" in prod
OPENEMR_VERIFY_TLS=
