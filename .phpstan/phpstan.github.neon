includes:
  - extension.neon
  - baseline/loader.php
parameters:
  reportUnmatchedIgnoredErrors: true
  strictRules:
    allRules: false
    disallowedEmpty: true
  scanDirectories:
    - ../vendor/adodb/adodb-php
  scanFiles:
    - ../vendor/phpunit/phpunit/src/Framework/TestCase.php
  excludePaths:
    - ../tests/Rector
  ignoreErrors:
    # Doctrine entities have properties set via reflection, not constructors
    - identifier: property.uninitializedReadonly
      path: ../src/Entities/*
