includes:
  - extension.neon
  - baseline/loader.php
parameters:
  reportUnmatchedIgnoredErrors: true
  strictRules:
    allRules: false
    disallowedEmpty: true
  scanDirectories:
    - ../vendor/adodb/adodb-php
  scanFiles:
    - ../vendor/phpunit/phpunit/src/Framework/TestCase.php
  excludePaths:
    - ../tests/Rector
    # Fixture files for SqlReservedWordRuleTest deliberately contain SQL
    # patterns the rule should flag; excluding them keeps full-codebase
    # PHPStan runs from reporting those intentional bugs.
    - ../tests/Tests/Isolated/PHPStan/Sql/data
