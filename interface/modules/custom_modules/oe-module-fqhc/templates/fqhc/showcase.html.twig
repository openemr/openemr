{#
  FQHC design-system showcase (Step 1).

  Renders the host page content using the FQHC Web Components, and previews the
  shape of the future UDS Patient Snapshot (#14): the "reuse" demographics card
  with data, and the "new" UDS cards as empty-states. Server-rendered shell +
  Web Component islands — the documented FQHC UI pattern.

  Note: TwigContainer disables autoescaping, so dynamic values are escaped
  explicitly with |e('html') / |e('html_attr').

  @license https://github.com/openemr/openemr/blob/master/LICENSE GNU General Public License 3
#}
<div class="fqhc-root">
  <div class="fqhc-container">

    <fqhc-page-header
      heading="{{ heading|e('html_attr') }}"
      subheading="{{ subheading|e('html_attr') }}">
      <div slot="actions" class="fqhc-cluster">
        <fqhc-status-badge variant="info">Step 1 · design system</fqhc-status-badge>
      </div>
    </fqhc-page-header>

    <p style="color: var(--fqhc-text-muted); max-width: 64ch;">
      This page is the FQHC module host shell rendering the design-system
      foundation. It previews the layout of the upcoming
      <strong>UDS Patient Snapshot</strong>: demographics OpenEMR already
      captures are shown as data; the new UDS fields appear as empty-states
      until their capture steps land.
    </p>

    <div class="fqhc-grid">

      {# Reuse: demographics OpenEMR already captures (sample values here). #}
      <fqhc-card heading="Demographics (reused)">
        {% for row in demographics %}
          <fqhc-field-row
            label="{{ row.label|e('html_attr') }}"
            value="{{ row.value|e('html_attr') }}"></fqhc-field-row>
        {% endfor %}
      </fqhc-card>

      {# New: income & FPL — captured in #15. #}
      <fqhc-card heading="Income & Federal Poverty Level">
        <fqhc-empty-state message="Not yet recorded — income & FPL capture lands in step #15."></fqhc-empty-state>
      </fqhc-card>

      {# New: special populations — captured in #16. #}
      <fqhc-card heading="Special populations">
        <div class="fqhc-stack">
          <div class="fqhc-cluster">
            <fqhc-status-badge variant="neutral">Agricultural worker</fqhc-status-badge>
            <fqhc-status-badge variant="neutral">Homeless</fqhc-status-badge>
            <fqhc-status-badge variant="neutral">Public housing</fqhc-status-badge>
            <fqhc-status-badge variant="neutral">Veteran</fqhc-status-badge>
            <fqhc-status-badge variant="neutral">School-based</fqhc-status-badge>
          </div>
          <fqhc-empty-state message="None recorded — special-population capture lands in step #16."></fqhc-empty-state>
        </div>
      </fqhc-card>

      {# New: insurance → UDS payer — surfaced in #17. #}
      <fqhc-card heading="Insurance (UDS payer category)">
        <fqhc-empty-state message="Not yet classified — UDS payer mapping lands in step #17."></fqhc-empty-state>
      </fqhc-card>

      {# Component reference, so the design system is visible end-to-end. #}
      <fqhc-card heading="Status badges" class="fqhc-grid-wide">
        <div class="fqhc-cluster">
          <fqhc-status-badge variant="success">Eligible</fqhc-status-badge>
          <fqhc-status-badge variant="info">In progress</fqhc-status-badge>
          <fqhc-status-badge variant="warning">Recert due</fqhc-status-badge>
          <fqhc-status-badge variant="danger">Missing data</fqhc-status-badge>
          <fqhc-status-badge variant="neutral">Unknown</fqhc-status-badge>
        </div>
      </fqhc-card>

    </div>
  </div>
</div>
