{#
  UDS patient-characteristics report (epic #4).

  Renders Tables 3A, 3B, 4 and the ZIP Code Table for a reporting year, with the
  cross-table reconciliation status. Server-rendered shell + design-system
  components; tabular data uses the .fqhc-table style.

  Context:
    year        — selected reporting calendar year (int).
    yearOptions — list<int> of selectable years.
    report      — view model from OpenEMR\FQHC\Reporting\UdsReportPresenter::present().

  TwigContainer disables autoescaping, so values are escaped explicitly.

  @license https://github.com/openemr/openemr/blob/master/LICENSE GNU General Public License 3
#}
<div class="fqhc-root">
  <div class="fqhc-container">

    <fqhc-page-header
      heading="UDS Report — {{ year }}"
      subheading="Patient characteristics for {{ report.summary.cohortSize }} patient(s) seen in {{ year }}">
      <div slot="actions" class="fqhc-cluster">
        {% if report.summary.consistent %}
          <fqhc-status-badge variant="success">Reconciled</fqhc-status-badge>
        {% else %}
          <fqhc-status-badge variant="warning">Review needed</fqhc-status-badge>
        {% endif %}
      </div>
    </fqhc-page-header>

    <form method="get" class="fqhc-row-between fqhc-inline-form">
      <div class="fqhc-field">
        <label for="year">Reporting year</label>
        <select id="year" name="year" onchange="this.form.submit()">
          {% for option in yearOptions %}
            <option value="{{ option }}"{{ option == year ? ' selected' : '' }}>{{ option }}</option>
          {% endfor %}
        </select>
      </div>
      <button type="submit" class="fqhc-button">View</button>
    </form>

    {% if report.summary.cohortSize == 0 %}
      <fqhc-card heading="No patients">
        <fqhc-empty-state message="No patients had a visit in {{ year }}."></fqhc-empty-state>
      </fqhc-card>
    {% else %}
      <div class="fqhc-stack">

        {% if not report.summary.consistent %}
          <fqhc-card heading="Reconciliation">
            <p class="fqhc-note">
              The unduplicated patient totals do not yet agree across all tables
              (patient totals agree: {{ report.summary.patientTotalsAgree ? 'yes' : 'no' }};
              ZIP insurance columns match Table 4: {{ report.summary.zipColumnsAgree ? 'yes' : 'no' }}).
              Patients missing an age or sex are dropped from Tables 3A/4 and need data-quality cleanup.
            </p>
          </fqhc-card>
        {% endif %}

        <fqhc-card heading="Table 4 — Income as a percentage of the Federal Poverty Level">
          <div class="fqhc-table-wrap">
            <table class="fqhc-table">
              <thead><tr><th>Income band</th><th>Patients</th></tr></thead>
              <tbody>
                {% for row in report.income.rows %}
                  <tr><td>{{ row.label|e('html') }}</td><td data-label="Patients">{{ row.count }}</td></tr>
                {% endfor %}
              </tbody>
              <tfoot><tr><th>Total patients</th><th data-label="Patients">{{ report.income.total }}</th></tr></tfoot>
            </table>
          </div>
        </fqhc-card>

        <fqhc-card heading="Table 4 — Principal third-party medical insurance">
          <div class="fqhc-table-wrap">
            <table class="fqhc-table">
              <thead><tr><th>Category</th><th>0–17</th><th>18 and over</th><th>Total</th></tr></thead>
              <tbody>
                {% for row in report.insurance.rows %}
                  <tr>
                    <td>{{ row.label|e('html') }}</td>
                    <td data-label="0–17">{{ row.age0to17 }}</td>
                    <td data-label="18 and over">{{ row.age18AndOver }}</td>
                    <td data-label="Total">{{ row.total }}</td>
                  </tr>
                {% endfor %}
              </tbody>
              <tfoot><tr><th>Total patients</th><th></th><th></th><th data-label="Total">{{ report.insurance.total }}</th></tr></tfoot>
            </table>
          </div>
        </fqhc-card>

        <fqhc-card heading="Table 4 — Special populations">
          <div class="fqhc-table-wrap">
            <table class="fqhc-table">
              <thead><tr><th>Population</th><th>Patients</th></tr></thead>
              <tbody>
                {% for row in report.specialPopulations %}
                  <tr><td>{{ row.label|e('html') }}</td><td data-label="Patients">{{ row.count }}</td></tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </fqhc-card>

        <fqhc-card heading="Table 3A — Patients by age and by sex">
          <div class="fqhc-table-wrap">
            <table class="fqhc-table">
              <thead><tr><th>Age group</th><th>Male</th><th>Female</th><th>Total</th></tr></thead>
              <tbody>
                {% for row in report.ageSex.rows %}
                  <tr>
                    <td>{{ row.label|e('html') }}</td>
                    <td data-label="Male">{{ row.male }}</td>
                    <td data-label="Female">{{ row.female }}</td>
                    <td data-label="Total">{{ row.total }}</td>
                  </tr>
                {% endfor %}
              </tbody>
              <tfoot>
                <tr><th>Total patients</th><th data-label="Male">{{ report.ageSex.male }}</th><th data-label="Female">{{ report.ageSex.female }}</th><th data-label="Total">{{ report.ageSex.total }}</th></tr>
              </tfoot>
            </table>
          </div>
        </fqhc-card>

        <fqhc-card heading="Table 3B — Race and Hispanic/Latino ethnicity">
          <div class="fqhc-table-wrap">
            <table class="fqhc-table">
              <thead><tr><th>Race</th><th>Hispanic</th><th>Not Hispanic</th><th>Unreported</th><th>Total</th></tr></thead>
              <tbody>
                {% for row in report.race.rows %}
                  <tr class="{{ row.detail ? 'fqhc-table-detail' : '' }}">
                    <td>{{ row.label|e('html') }}</td>
                    <td data-label="Hispanic">{{ row.hispanic }}</td>
                    <td data-label="Not Hispanic">{{ row.notHispanic }}</td>
                    <td data-label="Unreported">{{ row.unreported }}</td>
                    <td data-label="Total">{{ row.total }}</td>
                  </tr>
                {% endfor %}
              </tbody>
              <tfoot>
                <tr><th>Total patients</th><th data-label="Hispanic">{{ report.race.hispanic }}</th><th data-label="Not Hispanic">{{ report.race.notHispanic }}</th><th data-label="Unreported">{{ report.race.unreported }}</th><th data-label="Total">{{ report.race.total }}</th></tr>
              </tfoot>
            </table>
          </div>
          <fqhc-field-row label="Best served in a language other than English" value="{{ report.race.language }}"></fqhc-field-row>
        </fqhc-card>

        <fqhc-card heading="Patients by ZIP Code">
          <div class="fqhc-table-wrap">
            <table class="fqhc-table">
              <thead><tr><th>ZIP</th><th>Uninsured</th><th>Medicaid / CHIP / Other Public</th><th>Medicare</th><th>Private</th><th>Total</th></tr></thead>
              <tbody>
                {% for row in report.zip.rows %}
                  <tr>
                    <td>{{ row.label|e('html') }}</td>
                    <td data-label="Uninsured">{{ row.uninsured }}</td>
                    <td data-label="Medicaid / CHIP / Other Public">{{ row.publicInsurance }}</td>
                    <td data-label="Medicare">{{ row.medicare }}</td>
                    <td data-label="Private">{{ row.private }}</td>
                    <td data-label="Total">{{ row.total }}</td>
                  </tr>
                {% endfor %}
              </tbody>
              <tfoot>
                <tr><th>Total patients</th><th data-label="Uninsured">{{ report.zip.uninsured }}</th><th data-label="Medicaid / CHIP / Other Public">{{ report.zip.publicInsurance }}</th><th data-label="Medicare">{{ report.zip.medicare }}</th><th data-label="Private">{{ report.zip.private }}</th><th data-label="Total">{{ report.zip.total }}</th></tr>
              </tfoot>
            </table>
          </div>
        </fqhc-card>

        <fqhc-card heading="Table 5 — Utilization by service category">
          <div class="fqhc-table-wrap">
            <table class="fqhc-table">
              <thead><tr><th>Service category</th><th>In-person</th><th>Virtual</th><th>Total visits</th><th>Patients</th></tr></thead>
              <tbody>
                {% for row in table5.rows %}
                  <tr>
                    <td>{{ row.label|e('html') }}</td>
                    <td data-label="In-person">{{ row.clinic }}</td>
                    <td data-label="Virtual">{{ row.virtual }}</td>
                    <td data-label="Total visits">{{ row.visits }}</td>
                    <td data-label="Patients">{{ row.patients }}</td>
                  </tr>
                {% endfor %}
              </tbody>
              <tfoot>
                <tr><th>Total</th><th data-label="In-person">{{ table5.clinic }}</th><th data-label="Virtual">{{ table5.virtual }}</th><th data-label="Total visits">{{ table5.visits }}</th><th data-label="Patients">{{ table5.patients }}</th></tr>
              </tfoot>
            </table>
          </div>
          <p class="fqhc-note">Patients are counted once per service category (duplicated across categories), so the patient total is not the unduplicated health-center count. Staffing/FTE (Column A) is not yet included.</p>
        </fqhc-card>

        <fqhc-card heading="Table 6B — Clinical quality measures">
          <div class="fqhc-table-wrap">
            <table class="fqhc-table">
              <thead><tr><th>Measure</th><th>eCQM</th><th>Denominator</th><th>Numerator</th><th>Rate</th><th>Status</th></tr></thead>
              <tbody>
                {% for row in table6b.rows %}
                  <tr>
                    <td>{{ row.label|e('html') }}</td>
                    <td data-label="eCQM">{{ row.cmsId|e('html') }}</td>
                    <td data-label="Denominator">{{ row.computed ? row.denominator : '—' }}</td>
                    <td data-label="Numerator">{{ row.computed ? row.numerator : '—' }}</td>
                    <td data-label="Rate">{{ row.computed and row.rate is not null ? (row.rate * 100)|round(1) ~ '%' : '—' }}</td>
                    <td data-label="Status">
                      {% if row.computed %}
                        <fqhc-status-badge variant="success">Computed</fqhc-status-badge>
                      {% else %}
                        <fqhc-status-badge variant="neutral">Not yet computed</fqhc-status-badge>
                      {% endif %}
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
          <p class="fqhc-note">Measures are mapped to their CY2026 CMS eCQM (docs/fqhc/UDS-DATA-MODEL.md §3); population counts are pending the CQM/AMC engine population-set wiring.</p>
        </fqhc-card>

        <fqhc-card heading="Table 7 — Health outcomes and disparities">
          <div class="fqhc-table-wrap">
            <table class="fqhc-table">
              <thead><tr><th>Measure</th><th>Rate</th><th>Status</th></tr></thead>
              <tbody>
                {% for row in table7.rows %}
                  <tr>
                    <td>{{ row.label|e('html') }}</td>
                    <td data-label="Rate">{{ row.computed and row.rate is not null ? (row.rate * 100)|round(1) ~ '%' : '—' }}</td>
                    <td data-label="Status">
                      {% if row.computed %}
                        <fqhc-status-badge variant="success">Computed</fqhc-status-badge>
                      {% else %}
                        <fqhc-status-badge variant="neutral">Not yet computed</fqhc-status-badge>
                      {% endif %}
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
          <p class="fqhc-note">Early entry into prenatal care and low birth weight are not eCQM-backed and are not yet represented on this table; disparity stratification by race/ethnicity/sex is not yet built.</p>
        </fqhc-card>

      </div>
    {% endif %}

  </div>
</div>
