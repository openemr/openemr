<script>
(function () {
    var dropZone  = document.getElementById('dropZone');
    var fileInput = document.getElementById('moduleZipInput');
    var urlInput  = document.getElementById('moduleUrlInput');
    var fileLabel = document.getElementById('fileSelected');
    var dropLabel = document.getElementById('dropLabel');
    var checkbox  = document.getElementById('disclaimerCheck');
    var uploadBtn = document.getElementById('uploadBtn');
    var fileMethodBtn = document.getElementById('fileMethodBtn');
    var urlMethodBtn = document.getElementById('urlMethodBtn');
    var fileSection = document.getElementById('fileUploadSection');
    var urlSection = document.getElementById('urlDownloadSection');

    function updateBtn() {
        if (!uploadBtn || !checkbox || !checkbox.checked) {
            uploadBtn.disabled = true;
            return;
        }
        
        var fileMethod = document.getElementById('fileMethod').checked;
        if (fileMethod) {
            uploadBtn.disabled = !(fileInput && fileInput.files.length > 0);
        } else {
            uploadBtn.disabled = !(urlInput && urlInput.value.trim().length > 0);
        }
    }

    function setFile(name) {
        dropLabel.textContent = name;
        fileLabel.textContent = '\u2714 ' + name;
        fileLabel.style.display = 'block';
    }

    function switchToFileMethod() {
        fileSection.style.display = 'block';
        urlSection.style.display = 'none';
        fileMethodBtn.classList.add('active');
        urlMethodBtn.classList.remove('active');
        updateBtn();
    }

    function switchToUrlMethod() {
        fileSection.style.display = 'none';
        urlSection.style.display = 'block';
        fileMethodBtn.classList.remove('active');
        urlMethodBtn.classList.add('active');
        updateBtn();
    }

    // Method toggle handlers
    if (fileMethodBtn) {
        fileMethodBtn.addEventListener('click', switchToFileMethod);
    }
    if (urlMethodBtn) {
        urlMethodBtn.addEventListener('click', switchToUrlMethod);
    }

    // File input handlers
    if (fileInput) {
        fileInput.addEventListener('change', function () {
            if (fileInput.files.length > 0) { setFile(fileInput.files[0].name); }
            updateBtn();
        });
    }

    // URL input handler
    if (urlInput) {
        urlInput.addEventListener('input', updateBtn);
    }

    if (checkbox) { checkbox.addEventListener('change', updateBtn); }

    // Drag and drop handlers
    if (dropZone) {
        dropZone.addEventListener('keydown', function (e) {
            if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); fileInput.click(); }
        });
        dropZone.addEventListener('dragover', function (e) {
            e.preventDefault();
            dropZone.classList.add('dragover');
        });
        dropZone.addEventListener('dragleave', function () {
            dropZone.classList.remove('dragover');
        });
        dropZone.addEventListener('drop', function (e) {
            e.preventDefault();
            dropZone.classList.remove('dragover');
            var dt = e.dataTransfer;
            if (dt.files.length) {
                try { fileInput.files = dt.files; } catch (ex) {}
                setFile(dt.files[0].name);
                updateBtn();
            }
        });
    }
})();
</script>
